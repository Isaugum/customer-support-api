{
  "info": {
    "name": "Customer Support API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Full demo flow: User opens ticket → Operator logs in → Operator takes ticket → Both chat over WebSocket.\n\nAuth is handled via HttpOnly cookies — Postman's cookie jar picks them up automatically. Run requests top to bottom."
  },
  "item": [
    {
      "name": "1 · Auth",
      "item": [
        {
          "name": "Login as User (miha)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login succeeded', () => pm.response.to.have.status(200));",
                  "",
                  "const cookie = pm.cookies.get('jwt');",
                  "const payload = JSON.parse(atob(cookie.split('.')[1]));",
                  "pm.environment.set('user_id', payload.sub);",
                  "",
                  "console.log('user_id =', payload.sub);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"miha@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Logs in as a USER. Sets the `jwt` HttpOnly cookie automatically. Captures `user_id` from the JWT payload."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout succeeded', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Clears the `jwt` cookie."
          }
        },
        {
          "name": "Login as Operator (tone)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login succeeded', () => pm.response.to.have.status(200));",
                  "",
                  "const cookie = pm.cookies.get('jwt');",
                  "const payload = JSON.parse(atob(cookie.split('.')[1]));",
                  "pm.environment.set('operator_id', payload.sub);",
                  "",
                  "console.log('operator_id =', payload.sub);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tone@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Logs in as an OPERATOR, replacing the active session. Captures `operator_id` from the JWT payload."
          }
        }
      ]
    },
    {
      "name": "2 · Tickets (User)",
      "item": [
        {
          "name": "Open Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resp = pm.response.json();",
                  "pm.test('Ticket created', () => pm.response.to.have.status(201));",
                  "pm.test('Status is WAITING', () => pm.expect(resp.status).to.eql('WAITING'));",
                  "",
                  "pm.environment.set('ticket_id', resp.id);",
                  "console.log('ticket_id =', resp.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomId\": 1,\n  \"initialMessage\": \"My internet is down, please help!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/ticket/new",
              "host": ["{{base_url}}"],
              "path": ["ticket", "new"]
            },
            "description": "Opens a new ticket as the user. Automatically stores `ticket_id` in the environment.\n\nRequires being logged in as a USER (run 'Login as User' first).\n\nRooms (seeded):\n- 1 = Tehnika (Technical)\n- 2 = Storitve (Services)\n- 3 = Pogovor (Chat)"
          }
        }
      ]
    },
    {
      "name": "3 · Tickets (Operator)",
      "item": [
        {
          "name": "View All Tickets",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Got ticket list', () => pm.response.to.have.status(200));",
                  "",
                  "const tickets = pm.response.json();",
                  "const waiting = tickets.filter(t => t.status === 'WAITING');",
                  "console.log(`Total: ${tickets.length}, Waiting: ${waiting.length}`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ticket/all",
              "host": ["{{base_url}}"],
              "path": ["ticket", "all"],
              "query": [
                { "key": "status", "value": "WAITING", "disabled": true, "description": "Filter by status: WAITING, ACTIVE, CLOSED. Omit to return all." },
                { "key": "sort", "value": "updatedAt", "disabled": true, "description": "Sort field: updatedAt (default) or createdAt" },
                { "key": "order", "value": "desc", "disabled": true, "description": "Sort direction: desc (default) or asc" }
              ]
            },
            "description": "Returns all tickets. OPERATOR role required.\n\nQuery params (all optional):\n- `status` — WAITING, ACTIVE, or CLOSED. Omit to return all.\n- `sort` — `updatedAt` (default) or `createdAt`\n- `order` — `desc` (default) or `asc`"
          }
        },
        {
          "name": "Get Ticket by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Got ticket', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ticket/{{ticket_id}}",
              "host": ["{{base_url}}"],
              "path": ["ticket", "{{ticket_id}}"]
            },
            "description": "Fetch a single ticket by ID. Uses `ticket_id` captured from the Open Ticket step."
          }
        },
        {
          "name": "Take Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resp = pm.response.json();",
                  "pm.test('Ticket taken', () => pm.response.to.have.status(200));",
                  "pm.test('Status is ACTIVE', () => pm.expect(resp.status).to.eql('ACTIVE'));",
                  "pm.test('Operator assigned', () => pm.expect(resp.operatorId).to.not.be.null);",
                  "",
                  "console.log('Ticket is now ACTIVE, operatorId =', resp.operatorId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/ticket/{{ticket_id}}/take",
              "host": ["{{base_url}}"],
              "path": ["ticket", "{{ticket_id}}", "take"]
            },
            "description": "Operator claims the ticket. Transitions status WAITING → ACTIVE. Operator ID is read from the JWT cookie."
          }
        },
        {
          "name": "Close Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resp = pm.response.json();",
                  "pm.test('Ticket closed', () => pm.response.to.have.status(200));",
                  "pm.test('Status is CLOSED', () => pm.expect(resp.status).to.eql('CLOSED'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/ticket/{{ticket_id}}/close",
              "host": ["{{base_url}}"],
              "path": ["ticket", "{{ticket_id}}", "close"]
            },
            "description": "Closes the ACTIVE ticket. Only the operator who took the ticket can close it. Transitions status ACTIVE → CLOSED.\n\nNote: Close and Archive (below) are mutually exclusive — run only one per demo flow."
          }
        },
        {
          "name": "Archive Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resp = pm.response.json();",
                  "pm.test('Ticket archived', () => pm.response.to.have.status(200));",
                  "pm.test('Status is ARCHIVED', () => pm.expect(resp.status).to.eql('ARCHIVED'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/ticket/{{ticket_id}}/archive",
              "host": ["{{base_url}}"],
              "path": ["ticket", "{{ticket_id}}", "archive"]
            },
            "description": "Moves a CLOSED ticket to ARCHIVED status, hiding it from the active queue. Run this after Close Ticket above — archive requires the ticket to already be CLOSED. Only the operator who closed the ticket can archive it."
          }
        }
      ]
    },
    {
      "name": "4 · WebSocket Chat",
      "description": "WebSocket connections cannot be sent as REST requests.\n\n**How to connect in Postman:**\n1. Press **New → WebSocket**\n2. Enter the URL from the request below\n3. Click **Connect** — Postman sends the `jwt` cookie automatically during the HTTP upgrade handshake\n4. On success, message history is pushed immediately, then send plain text to chat\n\n**For the two-participant flow:**\n1. Ensure you are logged in as the user (run 'Login as User' in section 1), then open the user WebSocket tab and connect\n2. Then run 'Login as Operator' in section 3 to switch sessions, then open the operator WebSocket tab and connect\n3. Both connections stay open simultaneously — auth is checked once at connect time\n\nAll connections are rejected if the user is not the ticket creator or the assigned operator. The server closes all open sessions automatically when a ticket is CLOSED or ARCHIVED.",
      "item": [
        {
          "name": "User connects to chat",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{ws_url}}/chat/{{ticket_id}}",
              "host": ["{{ws_url}}"],
              "path": ["chat", "{{ticket_id}}"]
            },
            "description": "▶ Open as a WebSocket request in Postman (New → WebSocket).\n\nMake sure you are logged in as the USER before connecting (run 'Login as User' first). Postman sends the `jwt` cookie automatically — no headers needed.\n\nThe server validates the cookie during the HTTP upgrade and checks that this user is the ticket creator. Rejected connections receive an immediate close frame."
          }
        },
        {
          "name": "Operator connects to chat",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{ws_url}}/chat/{{ticket_id}}",
              "host": ["{{ws_url}}"],
              "path": ["chat", "{{ticket_id}}"]
            },
            "description": "▶ Open as a WebSocket request in Postman (New → WebSocket) in a separate tab.\n\nMake sure you are logged in as the OPERATOR before connecting (run 'Login as Operator' in section 3 first). Postman sends the `jwt` cookie automatically — no headers needed.\n\nThe operator must have taken the ticket first. When the ticket is closed or archived, the server drops all open sessions automatically."
          }
        }
      ]
    },
    {
      "name": "5 · Error cases",
      "item": [
        {
          "name": "Take ticket twice (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 400 on double-take', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/ticket/{{ticket_id}}/take",
              "host": ["{{base_url}}"],
              "path": ["ticket", "{{ticket_id}}", "take"]
            },
            "description": "Attempting to take an already-ACTIVE ticket returns 400 BadRequest: 'Ticket is already taken'."
          }
        },
        {
          "name": "Get ticket without auth (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401 without token', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ticket/all",
              "host": ["{{base_url}}"],
              "path": ["ticket", "all"]
            },
            "description": "Calling an operator-only endpoint without a token returns 401.\n\nNote: Run this before logging in, or manually delete the `jwt` cookie from Postman's cookie jar first (top menu → Cookies)."
          }
        },
        {
          "name": "Operator endpoint with user token (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 403 for wrong role', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ticket/all",
              "host": ["{{base_url}}"],
              "path": ["ticket", "all"]
            },
            "description": "Calling an OPERATOR-only endpoint while logged in as a USER returns 403 Forbidden.\n\nMake sure you are logged in as a user (run 'Login as User' in section 1) before running this."
          }
        },
        {
          "name": "Invalid sort field (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 400 for invalid sort', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ticket/all?sort=badField",
              "host": ["{{base_url}}"],
              "path": ["ticket", "all"],
              "query": [{ "key": "sort", "value": "badField" }]
            },
            "description": "Passing an unsupported sort field returns 400 BadRequest."
          }
        },
        {
          "name": "Get non-existent ticket (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 404 for missing ticket', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ticket/99999",
              "host": ["{{base_url}}"],
              "path": ["ticket", "99999"]
            },
            "description": "Requesting a ticket ID that does not exist returns 404 NotFoundException."
          }
        }
      ]
    }
  ],
  "variable": []
}
